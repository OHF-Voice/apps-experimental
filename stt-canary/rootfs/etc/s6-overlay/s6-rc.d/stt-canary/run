#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Start stt-canary service
# ==============================================================================
cd /usr/src

flags=()

if bashio::config.true 'debug_logging'; then
    flags+=('--debug')
fi

exec python3 app.py \
    --uri 'tcp://0.0.0.0:10300' \
    --model "$(bashio::config 'model')" \
    --cache-dir /data \
    ${flags[@]}
